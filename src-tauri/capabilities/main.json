{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Allow main window to access required plugins",
  "windows": ["main"],
  "permissions": [
    "shell:default",
    "dialog:default",
    "fs:default",
    "fs:read-all",
    "fs:write-all"
  ]
}
